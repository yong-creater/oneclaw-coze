# ============================================================
# OneClaw 管理后台环境变量配置
# ============================================================

# ============================================================
# 数据库配置 (火山引擎 PostgreSQL)
# ============================================================
# 从扣子编程的"数据库"页面获取以下配置
PGHOST=your_pg_host
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=postgres

# ============================================================
# 备选：使用 Supabase
# ============================================================
# COZE_SUPABASE_URL=your_supabase_url
# COZE_SUPABASE_ANON_KEY=your_supabase_anon_key
