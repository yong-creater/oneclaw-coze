# ============================================================
# OneClaw 管理后台环境变量配置
# ============================================================

# ============================================================
# 方案一：使用火山引擎 PostgreSQL（推荐，已有的扣子编程数据库）
# 必须与主站使用相同的数据库
# ============================================================
# 火山引擎 PostgreSQL 连接配置（从扣子编程的"生产数据库"页面获取）
DATABASE_URL=postgresql://postgres:[你的密码]@[你的PGHOST]:5432/postgres

# 或者使用单独的参数：
# PGHOST=cp-xxxxx.pg5.aidap-global.cn-beijing.volces.com
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=你的密码
# PGDATABASE=postgres

# ============================================================
# 方案二：使用 Supabase
# ============================================================
# COZE_SUPABASE_URL=https://your-project.supabase.co
# COZE_SUPABASE_ANON_KEY=your_anon_key_here
