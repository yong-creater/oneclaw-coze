# ============================================================
# OneClaw 管理后台环境变量配置
# ============================================================

# ============================================================
# 数据库配置 (Supabase) - 必须配置
# 必须与主站使用相同的 Supabase 项目
# ============================================================
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================
# 认证配置 (可选，有默认值)
# ============================================================
# AUTH_COOKIE_DOMAIN=.oneclaw.shop  # 跨域Cookie域名
# AUTH_JWT_SECRET=your_jwt_secret   # JWT密钥，必须与主站一致
