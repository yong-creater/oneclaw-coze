# ============================================================
# OneClaw 主站环境变量配置
# ============================================================

# ============================================================
# 数据库配置 (Supabase) - 必须配置
# ============================================================
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================
# 认证配置 (可选，有默认值)
# ============================================================
# AUTH_COOKIE_DOMAIN=.oneclaw.shop  # 跨域Cookie域名
# AUTH_JWT_SECRET=your_jwt_secret   # JWT密钥，默认自动生成

# ============================================================
# 小说创作工具 API 配置 (可选)
# ============================================================
# ENABLE_4SAPI=false
# API4S_KEY=your_4sapi_key

# ============================================================
# 管理后台密码 (可选)
# ============================================================
# ADMIN_PASSWORD=your_admin_password
