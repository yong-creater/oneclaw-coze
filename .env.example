# ============================================================
# OneClaw 环境变量配置
# ============================================================

# ============================================================
# 数据库配置 (Supabase)
# ============================================================
COZE_SUPABASE_URL=your_supabase_url
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# Coze SDK 配置（用于免费模型调用）
# ============================================================
# 从 Coze 平台获取的 API Key
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_api_key
# API 基础地址
COZE_INTEGRATION_BASE_URL=https://api.coze.com
# 模型基础地址
COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# ============================================================
# 自动化 Webhook 配置
# ============================================================
# Webhook 密钥（用于验证扣子等外部调用的合法性）
WEBHOOK_SECRET=oneclaw-webhook-secret-2024

# ============================================================
# 小说创作工具 API 配置 (4sapi - 付费模型)
# 注意：付费模型走 4sapi，免费模型走 Coze SDK
# ============================================================
# 付费模型开关（默认 false，只使用免费模型）
ENABLE_4SAPI=false
# API4S_KEY=your_4sapi_key  # 如需启用付费模型，取消注释并配置密钥
# API4S_URL=https://4sapi.com

# ============================================================
# 其他配置
# ============================================================
# ADMIN_PASSWORD=your_admin_password
