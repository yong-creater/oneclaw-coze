# ============================================================
# OneClaw 环境变量配置
# ============================================================

# ============================================================
# 数据库配置 (Supabase)
# ============================================================
COZE_SUPABASE_URL=your_supabase_url
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# 小说创作工具 API 配置 (4sapi)
# 注意：这些变量仅在后端使用，不会暴露到前端
# ============================================================
# 付费模型开关（默认 false，只使用免费模型）
ENABLE_4SAPI=false
# API4S_KEY=your_4sapi_key  # 如需启用付费模型，取消注释并配置密钥
# API4S_URL=https://4sapi.com

# ============================================================
# 其他配置
# ============================================================
# ADMIN_PASSWORD=your_admin_password
