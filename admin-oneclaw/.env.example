# OneClaw Admin 环境变量示例

# Supabase 配置（必须）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT 密钥（必须，所有应用使用相同密钥）
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-change-in-production

# Cookie 域名（根域名，用于 SSO）
COOKIE_DOMAIN=.oneclaw.shop

# 域名配置
MAIN_DOMAIN=oneclaw.shop
ADMIN_DOMAIN=admin.oneclaw.shop

# 当前应用标识
APP_ID=admin
